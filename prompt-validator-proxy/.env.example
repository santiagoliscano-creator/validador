# Copia este archivo como .env.local para probar en local con `vercel dev`.
# NUNCA subas el archivo .env.local real a GitHub (ya está en .gitignore).

# Tu API key de Anthropic (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Orígenes que pueden llamar a este proxy, separados por comas.
# Ejemplo: https://tu-usuario.github.io
# Si lo dejas vacío, cualquier sitio podría llamar al proxy (solo para pruebas).
ALLOWED_ORIGINS=https://tu-usuario.github.io
